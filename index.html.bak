          <ul>
            <li><a href="#modele">Notre modèle</a></li>
            <li><a href="#comment-ca-marche">Comment ça marche</a></li>
            <li><a href="#carrieres">Carrières</a></li>
            <li><a href="mailto:contact@babylon-agency.fr">Contact</a></li>
          </ul>
