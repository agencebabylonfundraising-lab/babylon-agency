      <div class="hero-ctas">
        <a href="mailto:contact@babylon-agency.fr" class="btn-primary">Demander une étude gratuite →</a>
        <a href="#comment-ca-marche" class="btn-secondary">Découvrir notre méthode</a>
      </div>
